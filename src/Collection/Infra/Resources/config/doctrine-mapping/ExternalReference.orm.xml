<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="App\Collection\Domain\ExternalReference" table="external_reference">
        <id name="uuid" column="uuid" type="uuid">
            <generator strategy="NONE"/>
        </id>
        <many-to-one field="album" target-entity="App\Collection\Domain\Album" inversed-by="externalReferences">
            <join-column name="album_uuid" referenced-column-name="uuid" nullable="false" on-delete="CASCADE" />
        </many-to-one>
        <field name="platform" column="platform" type="string" nullable="false" enum-type="App\Collection\Domain\PlatformEnum" />
        <field name="externalId" column="external_id" type="string" nullable="false"/>
        <field name="metadata" column="metadata" type="json" nullable="true"/>
        <unique-constraints>
            <unique-constraint columns="album_uuid,platform,external_id" name="uq_album_platform_external_id"/>
        </unique-constraints>
    </entity>
</doctrine-mapping>
