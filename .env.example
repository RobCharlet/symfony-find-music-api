# ------------------------------------------------------------------------------
# Application (Symfony runtime)
# ------------------------------------------------------------------------------
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=change-me-with-a-random-string
APP_SHARE_DIR=var/share
DEFAULT_URI=https://api.example.com

# ------------------------------------------------------------------------------
# CORS (NelmioCorsBundle)
# ------------------------------------------------------------------------------
# Single allowed origin for API calls
CORS_ALLOW_ORIGIN=https://app.example.com

# ------------------------------------------------------------------------------
# Messenger transport (kept on doctrine by default)
# ------------------------------------------------------------------------------
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

# ------------------------------------------------------------------------------
# Database (Doctrine)
# ------------------------------------------------------------------------------
# Must stay aligned with POSTGRES_* values below.
# IMPORTANT: the password in this URL must be the same as the value stored in DB_PASSWORD_FILE.
DATABASE_URL=postgresql://find_music:change_me@db:5432/find_music?serverVersion=16&charset=utf8

# ------------------------------------------------------------------------------
# JWT (LexikJWTAuthenticationBundle)
# ------------------------------------------------------------------------------
JWT_PASSPHRASE=change-me

# Paths on the Docker host used by docker-compose.prod.yml secrets
# Generate keys before first start:
#   symfony console lexik:jwt:generate-keypair --skip-if-exists
JWT_PRIVATE_KEY_FILE=./config/jwt/private.pem
JWT_PUBLIC_KEY_FILE=./config/jwt/public.pem

# ------------------------------------------------------------------------------
# Docker compose (production stack)
# ------------------------------------------------------------------------------
POSTGRES_VERSION=16
POSTGRES_DB=find_music
POSTGRES_USER=find_music
# DB password is now loaded via Docker secret (see secrets/ directory)
# Create the file before first start: echo "your_password" > secrets/db_password
# Keep this password identical to the password used in DATABASE_URL above.
DB_PASSWORD_FILE=./secrets/db_password
NGINX_PORT=8080

# Optional image tags
APP_IMAGE_TAG=latest
NGINX_IMAGE_TAG=latest
